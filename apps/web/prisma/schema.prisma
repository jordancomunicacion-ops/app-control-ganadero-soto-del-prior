generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  password      String
  role          String    @default("USER") // ADMIN, USER, VET
  approved      Boolean   @default(false)
  permissions   String[]  @default([]) // IDs of accessible sections: 'farms', 'animals', etc.
  
  // Extended Profile
  firstName     String?
  lastName      String?
  dni           String?
  phone         String?
  jobTitle      String?
  dob           DateTime?
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  resetToken       String?   @unique
  resetTokenExpiry DateTime?

  farms            Farm[]

  // Management Relation
  managedById      String?
  managedBy        User?     @relation("Management", fields: [managedById], references: [id])
  managedUsers     User[]    @relation("Management")

  @@index([managedById])
  @@index([role])
}

// 1. Entidades Principales (Referenciales y Estructurales)

model Farm {
  id                    String    @id @default(cuid())
  name                  String
  lat                   Float?
  lon                   Float?
  altitude              Float?
  defaultManagementSystem String? // extensivo, intensivo, mixto, ecologico

  // Tipo y propósito de la finca.
  //   farmType: define la intensidad productiva
  //     'extensivo'      → pastoreo libre, baja carga, gran superficie
  //     'semi_intensivo' → mixto con suplementación reglada
  //     'intensivo'      → estabulación parcial/total, cebaderos
  //   purpose: para qué se usa esta finca dentro del conjunto del ganadero
  //     'livestock' → solo ganado (puede tener corrales/cebadero pero NO produce cultivos)
  //     'cropland'  → solo cultivo destinado a consumo del ganado o venta
  //     'mixed'     → ambas cosas (dehesa tradicional, mixto secano)
  farmType              String?
  purpose               String?

  // Datos catastrales y geográficos
  municipio             String?
  municipioCode         String?
  provinciaCode         String?
  poligono              String?
  parcela               String?
  recintos              String?   // JSON
  coords                String?   // JSON
  superficie            Float     @default(0)
  license               String?
  maxHeads              Int       @default(0)
  soilId                String?

  // Legacy corral counters — conservados para retro-compatibilidad de UIs
  // antiguas. La fuente de verdad ahora es la relación `corralRecords`.
  corrals               Int       @default(0)
  corralNames           String?   // JSON o comma-separated

  feedingSystem         String?
  slope                 Float     @default(0)
  irrigationCoef        Float     @default(0)

  // Análisis y recomendaciones (JSON serializados)
  climateStudy          String?   // JSON
  cropsRecommendation   String?   // JSON
  breedsRecommendation  String?   // JSON
  f1Recommendation      String?   // JSON

  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  // Relación con propietario
  userId                String?
  user                  User?     @relation(fields: [userId], references: [id])

  // ── JERARQUÍA DE FINCAS ──────────────────────────────────────────────
  //
  // Una `Farm` con `parentFarmId = null` es una **finca principal**
  // (típicamente `purpose = livestock` o `mixed` — la dehesa madre donde
  // viven las vacas). Puede tener N fincas asociadas que la abastecen de
  // alimento, con `parentFarmId = id-de-la-principal` y normalmente
  // `purpose = cropland`.
  //
  // El sistema de identificación SIGPAC es el mismo en ambos niveles:
  // cada finca (principal o asociada) tiene su propia referencia (provincia
  // + municipio + polígono + parcela). Lo que las relaciona es solo este
  // `parentFarmId` — agrupación lógica del ganadero, no catastral.
  parentFarmId          String?
  parentFarm            Farm?     @relation("FarmHierarchy", fields: [parentFarmId], references: [id], onDelete: SetNull)
  childFarms            Farm[]    @relation("FarmHierarchy")

  // Relaciones
  animals               Animal[]
  dailyLogs             FarmDaily[]
  managementEvents      ManagementEvent[]
  corralRecords         Corral[]
  cropPlots             CropPlot[]
  pacDeclarations       PACDeclaration[]

  @@index([userId])
  @@index([userId, createdAt])
  @@index([parentFarmId])
}

// =============================================================================
// CORRAL — UNIDAD DE MANEJO DEL GANADO
// =============================================================================
//
// Un Corral representa DÓNDE ESTÁ EL GANADO físicamente. No es la unidad
// productiva de cultivo (esa es CropPlot — entidad distinta).
//
// Si el corral es un cercado de pastoreo sobre una pradera sembrada,
// usar `linkedPlotId` para vincularlo a la parcela de cultivo correspondiente.
// El cultivo concreto (alfalfa, ryegrass, mezcla), su rotación, su uso PAC
// y su histórico de siembras viven en `CropPlot` / `CropRotation`, no aquí.
//
// Tipos de corral:
//   - 'pasto'              → cercado sobre pasto natural (sin siembra)
//   - 'pasto_mejorado'     → cercado sobre pradera sembrada (usar linkedPlotId)
//   - 'cementado_silo'     → cebadero cubierto con silo y comedero
//   - 'cubierto'           → nave cubierta (invernada / parto / lactantes)
//   - 'cebadero'           → cebadero al aire libre
//   - 'paritorio'          → corral pequeño para vacas a punto de parir
//   - 'enfermeria'         → aislamiento sanitario / cuarentena
//   - 'manejo'             → manga de manejo, embarcadero
//
// La capacidad estimada (capacityLU) y la superficie permiten validar la
// carga ganadera del corral contra el modelo Pulido / SoilEngine.
model Corral {
  id            String   @id @default(cuid())
  farmId        String
  farm          Farm     @relation(fields: [farmId], references: [id], onDelete: Cascade)

  name          String
  kind          String   // pasto / pasto_mejorado / cementado_silo / cubierto / cebadero / paritorio / enfermeria / manejo
  surfaceM2     Float?   // superficie útil
  capacityLU    Float?   // capacidad estimada (LU)

  hasShade      Boolean  @default(false)
  hasWater      Boolean  @default(true)
  hasFeeder     Boolean  @default(false)
  hasSilo       Boolean  @default(false)

  // Vínculo a la parcela de cultivo que se pastorea en este corral.
  // Solo aplica si kind = 'pasto_mejorado' (pradera sembrada). Para
  // pasto natural o cebaderos queda en NULL.
  linkedPlotId  String?
  linkedPlot    CropPlot? @relation("CorralPasture", fields: [linkedPlotId], references: [id], onDelete: SetNull)

  // @deprecated — usar linkedPlot.rotations en su lugar. Mantenido como
  // campo libre durante la transición para no perder datos existentes.
  currentCrop   String?
  // Última siega/pastoreo (para programa de descanso)
  lastGrazedAt  DateTime?

  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([farmId])
  @@index([linkedPlotId])
}

// =============================================================================
// CROP PLOT — UNIDAD DE PRODUCCIÓN DE ALIMENTO
// =============================================================================
//
// Un CropPlot representa DÓNDE CRECE LA COMIDA. Es distinto del Corral, que
// es donde está el ganado. Una pradera sembrada puede ser ambas cosas:
// produce alimento (CropPlot) y se pastorea sobre ella (Corral con
// linkedPlotId apuntando a este plot).
//
// El destino productivo de cada siembra (pastoreo directo, henificación,
// ensilado, grano, venta, mejora de suelo) se decide por temporada en
// `CropRotation.destinationFor`, no aquí — porque puede cambiar año a año.
//
// Lleva su propia referencia SIGPAC + PAC use code (puede diferir del de
// la finca-contenedora).
model CropPlot {
  id              String   @id @default(cuid())
  farmId          String
  farm            Farm     @relation(fields: [farmId], references: [id], onDelete: Cascade)

  name            String
  surfaceHa       Float    @default(0)

  // Suelo: por defecto hereda del Farm, pero puede ser distinto entre parcelas.
  soilId          String?

  // Riego
  irrigated       Boolean  @default(false)
  irrigationType  String?  // aspersion / goteo / inundacion / pivot

  // Datos catastrales / SIGPAC específicos de la parcela (si difieren de la finca)
  sigpacPoligono  String?
  sigpacParcela   String?
  sigpacRecinto   String?

  // PAC use code (SIGPAC USO):
  //   TA = Tierras arables
  //   PR = Pasto arbolado
  //   PA = Pasto arbustivo
  //   PS = Pradera permanente
  //   FO = Forestal
  //   VI = Viñedo
  //   OV = Olivar
  //   etc
  pacUseCode      String?
  pacRegime       String?  // 'secano' | 'regadio'

  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  rotations       CropRotation[]
  // Corrales que pastorean directamente sobre esta parcela (cuando la
  // producción se consume in situ en vez de cosecharse).
  grazingCorrals  Corral[] @relation("CorralPasture")

  @@index([farmId])
}

// =============================================================================
// CROP ROTATION — historial y planificación por parcela
// =============================================================================
//
// Cada fila es un cultivo concreto sembrado en una parcela durante una
// temporada. Permite construir el calendario y la rotación a 3-5 años.
model CropRotation {
  id               String   @id @default(cuid())
  plotId           String
  plot             CropPlot @relation(fields: [plotId], references: [id], onDelete: Cascade)

  cropName         String   // ej: "Cebada", "Veza", "Maíz Forrajero"
  cropFamily       String?  // 'Cereal Invierno' | 'Cereal Verano' | 'Leguminosa' | 'Pradera' | 'Barbecho'

  sowDate          DateTime
  harvestDate      DateTime?

  expectedYieldT   Float?   // toneladas previstas
  actualYieldT     Float?

  // Destino productivo de esta siembra concreta:
  //   'pastoreo_directo' → el ganado come la parcela in situ (no se cosecha)
  //   'henificacion'     → se siega y empaca como heno (silo seco)
  //   'ensilado'         → se siega y ensila en silo húmedo
  //   'grano'            → cosecha de grano para almacén o pienso propio
  //   'venta'            → comercialización fuera de la explotación
  //   'mejora_suelo'     → abono verde / cubierta sin cosechar
  //
  // El valor histórico 'consumo_animal' se mantiene para retro-compatibilidad
  // con datos antiguos sin distinción fina entre pastoreo y cosecha.
  destinationFor   String?  @default("pastoreo_directo")

  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([plotId])
  @@index([plotId, sowDate])
}

// =============================================================================
// PAC DECLARATION — Política Agraria Común (campaña anual)
// =============================================================================
//
// Una declaración por finca y campaña. Refleja las ayudas solicitadas y un
// estimado de cobro. Nota: no sustituye al SIGA/SGA oficial; solo lleva
// registro interno para que el ganadero pueda planificar.
model PACDeclaration {
  id                String   @id @default(cuid())
  farmId            String
  farm              Farm     @relation(fields: [farmId], references: [id], onDelete: Cascade)

  campaignYear      Int      // 2024, 2025, 2026...
  status            String   @default("borrador") // borrador | presentada | aprobada | rechazada | cobrada

  // Líneas de ayuda solicitadas (campaña 2023-2027 reformada)
  basePayment       Boolean  @default(false) // pago básico a la renta
  redistributive    Boolean  @default(false) // complemento redistributivo (primeras 30 ha)
  youngFarmer       Boolean  @default(false) // joven agricultor
  organicScheme     Boolean  @default(false) // ayuda producción ecológica
  coupledLivestock  Boolean  @default(false) // ayuda asociada vacuno cría/cebo/leche

  // Ecorregímenes (P1-P9). Almacenados como array de códigos:
  //   P1 = Pastoreo extensivo
  //   P2 = Siega sostenible
  //   P3 = Pastos húmedos
  //   P4 = Rotación con especies mejorantes
  //   P5 = Siembra directa
  //   P6 = Espacios de biodiversidad cultivo
  //   P7 = Mantenimiento elementos del paisaje
  //   P8 = Cubiertas vegetales en cultivo leñoso
  //   P9 = Cubiertas inertes
  ecoSchemes        String[] @default([])

  // Agregados (auto-calculables a partir de plots + animals, o introducidos a mano)
  totalEligibleHa   Float?
  totalLU           Float?
  estimatedPayment  Float?   // total estimado € campaña

  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([farmId, campaignYear])
  @@index([farmId])
}

model Breed {
  id                    String    @id // Código ej. CHA, MOR, WAG
  name                  String
  subspecies            String    // taurus, indicus, composito
  
  // Parámetros Funcionales de Referencia
  adultMaleWeight       Float
  adultFemaleWeight     Float
  refAdgFeedlot         Float
  refAdgPasture         Float
  refFcrFeedlot         Float
  
  heatTolerance         Float     // 0-1
  marblingPotential     Int       // 1-5
  calvingEase           Float     // 0-1 (renamed or kept as is, schema said %)
  
  // Nuevos Parámetros Sapiens (Fase 5)
  milkPotential         Int       @default(1) // 1-5
  conformationPotential Int       @default(3) // 1-6 (P-S scale: P=1, O=2, R=3, U=4, E=5, S=6)
  yieldPotential        Float     @default(0.55) // 0.50 - 0.70

  source                String?

  // Relaciones
  genotypesByMother     Genotype[] @relation("MotherBreed")
  genotypesByFather     Genotype[] @relation("FatherBreed")
}

model Genotype {
  id                    String    @id @default(cuid())
  type                  String    // pure, f1, mestizo, composito
  label                 String    // ej. "F1 MOR-CHA"
  confidence            Float     // 0-1
  functionalType        String    // infiltracion, crecimiento_magro, rustica_adaptada, composito

  // Genealogía Genética
  motherBreedId         String?
  motherBreed           Breed?    @relation("MotherBreed", fields: [motherBreedId], references: [id])
  fatherBreedId         String?
  fatherBreed           Breed?    @relation("FatherBreed", fields: [fatherBreedId], references: [id])

  // Overrides opcionales
  customAdg             Float?
  customFcr             Float?

  animals               Animal[]
}

model Animal {
  id                    String    @id // Crotal ES...
  farmId                String
  farm                  Farm      @relation(fields: [farmId], references: [id])
  
  sex                   String    // M, H
  birthDate             DateTime
  
  genotypeId            String
  genotype              Genotype  @relation(fields: [genotypeId], references: [id])

  motherId              String?   // ID Animal Madre
  mother                Animal?   @relation("Mother", fields: [motherId], references: [id])
  fatherId              String?   // ID Animal Padre
  father                Animal?   @relation("Father", fields: [fatherId], references: [id])

  status                String?    // activo, vendido, muerto, sacrificado

  // New Fields
  notes                 String?
  corral                String?
  category              String?
  breedName             String?   // For simple string storage if strict relation not used
  currentWeight         Float?

  // Genetic composition for heat-tolerance modelling. Stored explicitly so
  // F1 / composite animals where the breed string is "Cruzado" can still be
  // resolved against Gaughan/Mader HLI thresholds and Mateescu et al.
  // (2020) Brahman-gene body-temperature plasticity slopes.
  //   brahmanPercent: 0–1 (0=pure taurus, 1=pure Bos indicus)
  //   biotypeOverride: free-form override ("British" | "Continental" |
  //     "Rustic_European" | "Dairy" | "Indicus" | "Composite") to skip the
  //     name-based heuristic when the user knows better.
  brahmanPercent        Float?
  biotypeOverride       String?

  // Slaughter / Sale outcome (filled when status moves to vendido/sacrificado/muerto).
  // Persisted at the Animal level so reports can be generated without re-walking events.
  exitDate              DateTime?
  actualLiveWeight      Float?
  actualCarcassWeight   Float?
  actualYield           Float?   // rendimiento canal real (0–1)
  actualPrice           Float?   // total € paid
  actualPricePerKg      Float?   // €/kg canal
  actualSeuropConf      String?  // P / O / R / U / E / S
  actualSeuropFat       Int?     // 1–5
  actualCategory        String?  // V, Z, A, B, C, D, E (MAPA)
  deathReason           String?

  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  // Relaciones Inversas
  childrenAsMother      Animal[]  @relation("Mother")
  childrenAsFather      Animal[]  @relation("Father")

  weights               Weight[]
  rations               Ration[]
  events                ManagementEvent[]
  dailyMetrics          DailyMetric[]
  alerts                Alert[]
  qualityPredictions    QualityPrediction[]
  traceabilityReports   TraceabilityReport[]

  @@index([farmId])
  @@index([farmId, createdAt])
  @@index([genotypeId])
  @@index([motherId])
  @@index([fatherId])
}

model Weight {
  id                    String    @id @default(cuid())
  animalId              String
  animal                Animal    @relation(fields: [animalId], references: [id])
  
  date                  DateTime
  weightKg              Float
  method                String    // bascula, estimado

  @@unique([animalId, date])
}

// 2. Alimentación y Composición

model Feed {
  id                    String    @id @default(cuid())
  name                  String
  category              String    // pasto, forraje, concentrado, subproducto, suplemento
  
  // Nutricional (Base MS)
  dmPercent             Float
  cpPercentDm           Float
  fdnPercentDm          Float
  adfPercentDm          Float
  netEnergyMcalKgDm     Float
  
  riskLevel             String?   // bajo, medio, alto
  notes                 String?
  costPerKgFresh        Float     // €/kg fresco
  
  source                String?

  rationItems           RationItem[]
}

model Ration {
  id                    String    @id @default(cuid())
  animalId              String
  animal                Animal    @relation(fields: [animalId], references: [id])
  
  date                  DateTime
  objective             String    // calidad, eficiencia, acabado, rusticidad
  origin                String    // manual, recomendada, ajuste

  items                 RationItem[]

  @@unique([animalId, date])
}

model RationItem {
  id                    String    @id @default(cuid())
  rationId              String
  ration                Ration    @relation(fields: [rationId], references: [id])
  
  feedId                String
  feed                  Feed      @relation(fields: [feedId], references: [id])
  
  amountFreshKg         Float
  amountDmKg            Float?

  @@index([rationId])
  @@index([feedId])
}

// 3. Entorno y Manejo

model FarmDaily {
  id                    String    @id @default(cuid())
  farmId                String
  farm                  Farm      @relation(fields: [farmId], references: [id])
  
  date                  DateTime
  
  maxTemp               Float?
  minTemp               Float?
  humidity              Float?
  precipitation         Float?
  heatStressIndex       Float?
  
  notes                 String?

  @@unique([farmId, date])
}

model ManagementEvent {
  id                    String    @id @default(cuid())
  farmId                String
  farm                  Farm      @relation(fields: [farmId], references: [id])

  animalId              String?
  animal                Animal?   @relation(fields: [animalId], references: [id])

  date                  DateTime
  type                  String    // destete, cambio_lote, tratamiento, cambio_dieta, cubricion, parto, entrada_cebo, salida_cebo

  details               String?   // New: Description/Notes
  cost                  Float     @default(0)
  status                String    @default("completed") // scheduled, pending, completed
  eventData             String?   // JSON for extra data

  notes                 String?

  @@index([farmId, date])
  @@index([animalId])
}

// 4. Motor: Objetivos, Métricas, Alertas y Predicciones

model Target {
  id                    String    @id @default(cuid())
  functionalType        String    // infiltracion, crecimiento_magro...
  stage                 String    // pre_destete, recria, terminado...
  
  minEnergy             Float
  minProtein            Float
  minFdn                Float
  minConcentrate        Float
  maxConcentrate        Float
  
  refAdg                Float
  refFcr                Float
  
  version               Int       @default(1)
}

model DailyMetric {
  id                    String    @id @default(cuid())
  animalId              String
  animal                Animal    @relation(fields: [animalId], references: [id])
  
  date                  DateTime
  calculatedStage       String
  
  totalDmKg             Float
  dietEnergy            Float
  dietProtein           Float
  dietFdn               Float
  dietAdf               Float
  
  adgObserved           Float?
  fcrObserved           Float?
  
  adgPredicted          Float?
  fcrPredicted          Float?

  @@unique([animalId, date])
}

model Alert {
  id                    String    @id @default(cuid())
  animalId              String
  animal                Animal    @relation(fields: [animalId], references: [id])
  
  date                  DateTime
  type                  String    // acidosis_riesgo, baja_ganancia, ineficiencia...
  severity              String    // info, warning, critical
  message               String
  ruleCode              String    // ej. RISK_ACIDOSIS_01
  
  resolvedAt            DateTime?
}

model QualityPrediction {
  id                    String    @id @default(cuid())
  animalId              String
  animal                Animal    @relation(fields: [animalId], references: [id])
  
  date                  DateTime
  qualityIndex          Float     // 0-100
  
  predTenderness        Float?
  predMarbling          Float?
  predColor             String?
  
  confidence            Float     // 0-1
  modelVersion          String
}

model TraceabilityReport {
  id                    String    @id @default(cuid())
  animalId              String
  animal                Animal    @relation(fields: [animalId], references: [id])

  issueDate             DateTime
  summaryJson           String    // JSON string
  qrToken               String    @unique
}

// Weekly SEUROP / MAPA reference prices.
//
// `code` is the lookup key used by PriceEngine: either the full grid cell
// (e.g. "AR3", "CU3") or the class ("AR", "CU") or just the MAPA letter
// ("A", "C") as a coarser fallback. The latest non-null entry for a given
// code wins — `week` lets us audit history and keep multiple weeks for
// trend analysis.
//
// Refreshed by `app/api/cron/refresh-prices` (configurable feed via
// PRICES_FEED_URL) or by a manual admin action.
model Price {
  id            String   @id @default(cuid())
  code          String
  pricePer100Kg Float
  week          String   // ISO week key, e.g. "2026-W20"
  source        String   @default("custom") // lonja_salamanca, mapa, eu_observatory, manual, custom
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([code, week])
  @@index([code])
  @@index([week])
}
