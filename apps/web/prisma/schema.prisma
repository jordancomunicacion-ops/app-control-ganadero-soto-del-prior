generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  password      String
  role          String    @default("USER") // ADMIN, USER, VET
  approved      Boolean   @default(false)
  permissions   String[]  @default([]) // IDs of accessible sections: 'farms', 'animals', etc.
  
  // Extended Profile
  firstName     String?
  lastName      String?
  dni           String?
  phone         String?
  jobTitle      String?
  dob           DateTime?
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  resetToken       String?   @unique
  resetTokenExpiry DateTime?

  farms            Farm[]

  // Management Relation
  managedById      String?
  managedBy        User?     @relation("Management", fields: [managedById], references: [id])
  managedUsers     User[]    @relation("Management")

  @@index([managedById])
  @@index([role])
}

// 1. Entidades Principales (Referenciales y Estructurales)

model Farm {
  id                    String    @id @default(cuid())
  name                  String
  lat                   Float?
  lon                   Float?
  altitude              Float?
  defaultManagementSystem String? // extensivo, intensivo, mixto, ecologico

  // Tipo y propósito de la finca.
  //   farmType: define la intensidad productiva
  //     'extensivo'      → pastoreo libre, baja carga, gran superficie
  //     'semi_intensivo' → mixto con suplementación reglada
  //     'intensivo'      → estabulación parcial/total, cebaderos
  //   purpose: para qué se usa esta finca dentro del conjunto del ganadero
  //     'livestock' → solo ganado (puede tener corrales/cebadero pero NO produce cultivos)
  //     'cropland'  → solo cultivo destinado a consumo del ganado o venta
  //     'mixed'     → ambas cosas (dehesa tradicional, mixto secano)
  farmType              String?
  purpose               String?

  // Datos catastrales y geográficos
  municipio             String?
  municipioCode         String?
  provinciaCode         String?
  poligono              String?
  parcela               String?
  recintos              String?   // JSON
  coords                String?   // JSON
  superficie            Float     @default(0)
  license               String?
  maxHeads              Int       @default(0)
  soilId                String?

  // Legacy corral counters — conservados para retro-compatibilidad de UIs
  // antiguas. La fuente de verdad ahora es la relación `corralRecords`.
  corrals               Int       @default(0)
  corralNames           String?   // JSON o comma-separated

  feedingSystem         String?
  slope                 Float     @default(0)
  irrigationCoef        Float     @default(0)

  // Análisis y recomendaciones (JSON serializados)
  climateStudy          String?   // JSON
  cropsRecommendation   String?   // JSON
  breedsRecommendation  String?   // JSON
  f1Recommendation      String?   // JSON

  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  // Relación con propietario
  userId                String?
  user                  User?     @relation(fields: [userId], references: [id])

  // ── JERARQUÍA DE FINCAS ──────────────────────────────────────────────
  //
  // Una `Farm` con `parentFarmId = null` es una **finca principal**
  // (típicamente `purpose = livestock` o `mixed` — la dehesa madre donde
  // viven las vacas). Puede tener N fincas asociadas que la abastecen de
  // alimento, con `parentFarmId = id-de-la-principal` y normalmente
  // `purpose = cropland`.
  //
  // El sistema de identificación SIGPAC es el mismo en ambos niveles:
  // cada finca (principal o asociada) tiene su propia referencia (provincia
  // + municipio + polígono + parcela). Lo que las relaciona es solo este
  // `parentFarmId` — agrupación lógica del ganadero, no catastral.
  parentFarmId          String?
  parentFarm            Farm?     @relation("FarmHierarchy", fields: [parentFarmId], references: [id], onDelete: SetNull)
  childFarms            Farm[]    @relation("FarmHierarchy")

  // Relaciones
  animals               Animal[]
  dailyLogs             FarmDaily[]
  managementEvents      ManagementEvent[]
  corralRecords         Corral[]
  cropPlots             CropPlot[]
  pacDeclarations       PACDeclaration[]
  vetStockMovements     VetStockMovement[]
  campaignSchedules     CampaignSchedule[]
  grazingEvents         GrazingEvent[]
  emissionRecords       EmissionRecord[]
  simulations           Simulation[]
  costEntries           CostEntry[]
  alertRules            AlertRule[]
  welfareAssessments    WelfareAssessment[]

  @@index([userId])
  @@index([userId, createdAt])
  @@index([parentFarmId])
}

// =============================================================================
// CORRAL — UNIDAD DE MANEJO DEL GANADO
// =============================================================================
//
// Un Corral representa DÓNDE ESTÁ EL GANADO físicamente. No es la unidad
// productiva de cultivo (esa es CropPlot — entidad distinta).
//
// Si el corral es un cercado de pastoreo sobre una pradera sembrada,
// usar `linkedPlotId` para vincularlo a la parcela de cultivo correspondiente.
// El cultivo concreto (alfalfa, ryegrass, mezcla), su rotación, su uso PAC
// y su histórico de siembras viven en `CropPlot` / `CropRotation`, no aquí.
//
// Tipos de corral:
//   - 'pasto'              → cercado sobre pasto natural (sin siembra)
//   - 'pasto_mejorado'     → cercado sobre pradera sembrada (usar linkedPlotId)
//   - 'cementado_silo'     → cebadero cubierto con silo y comedero
//   - 'cubierto'           → nave cubierta (invernada / parto / lactantes)
//   - 'cebadero'           → cebadero al aire libre
//   - 'paritorio'          → corral pequeño para vacas a punto de parir
//   - 'enfermeria'         → aislamiento sanitario / cuarentena
//   - 'manejo'             → manga de manejo, embarcadero
//
// La capacidad estimada (capacityLU) y la superficie permiten validar la
// carga ganadera del corral contra el modelo Pulido / SoilEngine.
model Corral {
  id            String   @id @default(cuid())
  farmId        String
  farm          Farm     @relation(fields: [farmId], references: [id], onDelete: Cascade)

  name          String
  kind          String   // pasto / pasto_mejorado / cementado_silo / cubierto / cebadero / paritorio / enfermeria / manejo
  surfaceM2     Float?   // superficie útil
  capacityLU    Float?   // capacidad estimada (LU)

  hasShade      Boolean  @default(false)
  hasWater      Boolean  @default(true)
  hasFeeder     Boolean  @default(false)
  hasSilo       Boolean  @default(false)

  // Vínculo a la parcela de cultivo que se pastorea en este corral.
  // Solo aplica si kind = 'pasto_mejorado' (pradera sembrada). Para
  // pasto natural o cebaderos queda en NULL.
  linkedPlotId  String?
  linkedPlot    CropPlot? @relation("CorralPasture", fields: [linkedPlotId], references: [id], onDelete: SetNull)

  // @deprecated — usar linkedPlot.rotations en su lugar. Mantenido como
  // campo libre durante la transición para no perder datos existentes.
  currentCrop   String?
  // Última siega/pastoreo (para programa de descanso)
  lastGrazedAt  DateTime?

  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([farmId])
  @@index([linkedPlotId])
}

// =============================================================================
// CROP PLOT — UNIDAD DE PRODUCCIÓN DE ALIMENTO
// =============================================================================
//
// Un CropPlot representa DÓNDE CRECE LA COMIDA. Es distinto del Corral, que
// es donde está el ganado. Una pradera sembrada puede ser ambas cosas:
// produce alimento (CropPlot) y se pastorea sobre ella (Corral con
// linkedPlotId apuntando a este plot).
//
// El destino productivo de cada siembra (pastoreo directo, henificación,
// ensilado, grano, venta, mejora de suelo) se decide por temporada en
// `CropRotation.destinationFor`, no aquí — porque puede cambiar año a año.
//
// Lleva su propia referencia SIGPAC + PAC use code (puede diferir del de
// la finca-contenedora).
model CropPlot {
  id              String   @id @default(cuid())
  farmId          String
  farm            Farm     @relation(fields: [farmId], references: [id], onDelete: Cascade)

  name            String
  surfaceHa       Float    @default(0)

  // Suelo: por defecto hereda del Farm, pero puede ser distinto entre parcelas.
  soilId          String?

  // Riego
  irrigated       Boolean  @default(false)
  irrigationType  String?  // aspersion / goteo / inundacion / pivot

  // Datos catastrales / SIGPAC específicos de la parcela (si difieren de la finca)
  sigpacPoligono  String?
  sigpacParcela   String?
  sigpacRecinto   String?

  // PAC use code (SIGPAC USO):
  //   TA = Tierras arables
  //   PR = Pasto arbolado
  //   PA = Pasto arbustivo
  //   PS = Pradera permanente
  //   FO = Forestal
  //   VI = Viñedo
  //   OV = Olivar
  //   etc
  pacUseCode      String?
  pacRegime       String?  // 'secano' | 'regadio'

  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  rotations       CropRotation[]
  // Corrales que pastorean directamente sobre esta parcela (cuando la
  // producción se consume in situ en vez de cosecharse).
  grazingCorrals  Corral[] @relation("CorralPasture")

  @@index([farmId])
}

// =============================================================================
// CROP ROTATION — historial y planificación por parcela
// =============================================================================
//
// Cada fila es un cultivo concreto sembrado en una parcela durante una
// temporada. Permite construir el calendario y la rotación a 3-5 años.
model CropRotation {
  id               String   @id @default(cuid())
  plotId           String
  plot             CropPlot @relation(fields: [plotId], references: [id], onDelete: Cascade)

  cropName         String   // ej: "Cebada", "Veza", "Maíz Forrajero"
  cropFamily       String?  // 'Cereal Invierno' | 'Cereal Verano' | 'Leguminosa' | 'Pradera' | 'Barbecho'

  sowDate          DateTime
  harvestDate      DateTime?

  expectedYieldT   Float?   // toneladas previstas
  actualYieldT     Float?

  // Destino productivo de esta siembra concreta:
  //   'pastoreo_directo' → el ganado come la parcela in situ (no se cosecha)
  //   'henificacion'     → se siega y empaca como heno (silo seco)
  //   'ensilado'         → se siega y ensila en silo húmedo
  //   'grano'            → cosecha de grano para almacén o pienso propio
  //   'venta'            → comercialización fuera de la explotación
  //   'mejora_suelo'     → abono verde / cubierta sin cosechar
  //
  // El valor histórico 'consumo_animal' se mantiene para retro-compatibilidad
  // con datos antiguos sin distinción fina entre pastoreo y cosecha.
  destinationFor   String?  @default("pastoreo_directo")

  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([plotId])
  @@index([plotId, sowDate])
}

// =============================================================================
// PAC DECLARATION — Política Agraria Común (campaña anual)
// =============================================================================
//
// Una declaración por finca y campaña. Refleja las ayudas solicitadas y un
// estimado de cobro. Nota: no sustituye al SIGA/SGA oficial; solo lleva
// registro interno para que el ganadero pueda planificar.
model PACDeclaration {
  id                String   @id @default(cuid())
  farmId            String
  farm              Farm     @relation(fields: [farmId], references: [id], onDelete: Cascade)

  campaignYear      Int      // 2024, 2025, 2026...
  status            String   @default("borrador") // borrador | presentada | aprobada | rechazada | cobrada

  // Líneas de ayuda solicitadas (campaña 2023-2027 reformada)
  basePayment       Boolean  @default(false) // pago básico a la renta
  redistributive    Boolean  @default(false) // complemento redistributivo (primeras 30 ha)
  youngFarmer       Boolean  @default(false) // joven agricultor
  organicScheme     Boolean  @default(false) // ayuda producción ecológica
  coupledLivestock  Boolean  @default(false) // ayuda asociada vacuno cría/cebo/leche

  // Ecorregímenes (P1-P9). Almacenados como array de códigos:
  //   P1 = Pastoreo extensivo
  //   P2 = Siega sostenible
  //   P3 = Pastos húmedos
  //   P4 = Rotación con especies mejorantes
  //   P5 = Siembra directa
  //   P6 = Espacios de biodiversidad cultivo
  //   P7 = Mantenimiento elementos del paisaje
  //   P8 = Cubiertas vegetales en cultivo leñoso
  //   P9 = Cubiertas inertes
  ecoSchemes        String[] @default([])

  // Agregados (auto-calculables a partir de plots + animals, o introducidos a mano)
  totalEligibleHa   Float?
  totalLU           Float?
  estimatedPayment  Float?   // total estimado € campaña

  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([farmId, campaignYear])
  @@index([farmId])
}

model Breed {
  id                    String    @id // Código ej. CHA, MOR, WAG
  name                  String
  subspecies            String    // taurus, indicus, composito
  
  // Parámetros Funcionales de Referencia
  adultMaleWeight       Float
  adultFemaleWeight     Float
  refAdgFeedlot         Float
  refAdgPasture         Float
  refFcrFeedlot         Float
  
  heatTolerance         Float     // 0-1
  marblingPotential     Int       // 1-5
  calvingEase           Float     // 0-1 (renamed or kept as is, schema said %)
  
  // Nuevos Parámetros Sapiens (Fase 5)
  milkPotential         Int       @default(1) // 1-5
  conformationPotential Int       @default(3) // 1-6 (P-S scale: P=1, O=2, R=3, U=4, E=5, S=6)
  yieldPotential        Float     @default(0.55) // 0.50 - 0.70

  source                String?

  // Relaciones
  genotypesByMother     Genotype[] @relation("MotherBreed")
  genotypesByFather     Genotype[] @relation("FatherBreed")
}

model Genotype {
  id                    String    @id @default(cuid())
  type                  String    // pure, f1, mestizo, composito
  label                 String    // ej. "F1 MOR-CHA"
  confidence            Float     // 0-1
  functionalType        String    // infiltracion, crecimiento_magro, rustica_adaptada, composito

  // Genealogía Genética
  motherBreedId         String?
  motherBreed           Breed?    @relation("MotherBreed", fields: [motherBreedId], references: [id])
  fatherBreedId         String?
  fatherBreed           Breed?    @relation("FatherBreed", fields: [fatherBreedId], references: [id])

  // Overrides opcionales
  customAdg             Float?
  customFcr             Float?

  animals               Animal[]
}

model Animal {
  id                    String    @id // Crotal ES...
  farmId                String
  farm                  Farm      @relation(fields: [farmId], references: [id])

  sex                   String    // M, H
  birthDate             DateTime

  // Documento Identificación Bovina (España): suele coincidir con el crotal
  // pero se guarda aparte porque puede llegar por escaneo OCR/QR antes de
  // que el animal exista en el sistema (alta rápida desde móvil).
  dibCode               String?   @unique

  genotypeId            String
  genotype              Genotype  @relation(fields: [genotypeId], references: [id])

  motherId              String?   // ID Animal Madre
  mother                Animal?   @relation("Mother", fields: [motherId], references: [id])
  fatherId              String?   // ID Animal Padre
  father                Animal?   @relation("Father", fields: [fatherId], references: [id])

  status                String?    // activo, vendido, muerto, sacrificado

  // New Fields
  notes                 String?
  corral                String?
  category              String?
  breedName             String?   // For simple string storage if strict relation not used
  currentWeight         Float?

  // Foto principal (cara/perfil). El resto de fotos/eco/docs viven en
  // AnimalAttachment con type discriminado.
  photoUrl              String?

  // Genetic composition for heat-tolerance modelling. Stored explicitly so
  // F1 / composite animals where the breed string is "Cruzado" can still be
  // resolved against Gaughan/Mader HLI thresholds and Mateescu et al.
  // (2020) Brahman-gene body-temperature plasticity slopes.
  //   brahmanPercent: 0–1 (0=pure taurus, 1=pure Bos indicus)
  //   biotypeOverride: free-form override ("British" | "Continental" |
  //     "Rustic_European" | "Dairy" | "Indicus" | "Composite") to skip the
  //     name-based heuristic when the user knows better.
  brahmanPercent        Float?
  biotypeOverride       String?

  // Slaughter / Sale outcome (filled when status moves to vendido/sacrificado/muerto).
  // Persisted at the Animal level so reports can be generated without re-walking events.
  exitDate              DateTime?
  actualLiveWeight      Float?
  actualCarcassWeight   Float?
  actualYield           Float?   // rendimiento canal real (0–1)
  actualPrice           Float?   // total € paid
  actualPricePerKg      Float?   // €/kg canal
  actualSeuropConf      String?  // P / O / R / U / E / S
  actualSeuropFat       Int?     // 1–5
  actualCategory        String?  // V, Z, A, B, C, D, E (MAPA)
  deathReason           String?

  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  // Relaciones Inversas
  childrenAsMother      Animal[]  @relation("Mother")
  childrenAsFather      Animal[]  @relation("Father")

  weights               Weight[]
  rations               Ration[]
  events                ManagementEvent[]
  dailyMetrics          DailyMetric[]
  alerts                Alert[]
  qualityPredictions    QualityPrediction[]
  traceabilityReports   TraceabilityReport[]
  attachments           AnimalAttachment[]
  healthRecords         HealthRecord[]
  grazingEvents         GrazingEvent[]
  costEntries           CostEntry[]

  @@index([farmId])
  @@index([farmId, createdAt])
  @@index([genotypeId])
  @@index([motherId])
  @@index([fatherId])
}

model Weight {
  id                    String    @id @default(cuid())
  animalId              String
  animal                Animal    @relation(fields: [animalId], references: [id])
  
  date                  DateTime
  weightKg              Float
  method                String    // bascula, estimado

  @@unique([animalId, date])
}

// 2. Alimentación y Composición

model Feed {
  id                    String    @id @default(cuid())
  name                  String
  category              String    // pasto, forraje, concentrado, subproducto, suplemento
  
  // Nutricional (Base MS)
  dmPercent             Float
  cpPercentDm           Float
  fdnPercentDm          Float
  adfPercentDm          Float
  netEnergyMcalKgDm     Float
  
  riskLevel             String?   // bajo, medio, alto
  notes                 String?
  costPerKgFresh        Float     // €/kg fresco
  
  source                String?

  rationItems           RationItem[]
}

model Ration {
  id                    String    @id @default(cuid())
  animalId              String
  animal                Animal    @relation(fields: [animalId], references: [id])
  
  date                  DateTime
  objective             String    // calidad, eficiencia, acabado, rusticidad
  origin                String    // manual, recomendada, ajuste

  items                 RationItem[]

  @@unique([animalId, date])
}

model RationItem {
  id                    String    @id @default(cuid())
  rationId              String
  ration                Ration    @relation(fields: [rationId], references: [id])
  
  feedId                String
  feed                  Feed      @relation(fields: [feedId], references: [id])
  
  amountFreshKg         Float
  amountDmKg            Float?

  @@index([rationId])
  @@index([feedId])
}

// 3. Entorno y Manejo

model FarmDaily {
  id                    String    @id @default(cuid())
  farmId                String
  farm                  Farm      @relation(fields: [farmId], references: [id])
  
  date                  DateTime
  
  maxTemp               Float?
  minTemp               Float?
  humidity              Float?
  precipitation         Float?
  heatStressIndex       Float?
  
  notes                 String?

  @@unique([farmId, date])
}

model ManagementEvent {
  id                    String    @id @default(cuid())
  farmId                String
  farm                  Farm      @relation(fields: [farmId], references: [id])

  animalId              String?
  animal                Animal?   @relation(fields: [animalId], references: [id])

  date                  DateTime
  type                  String    // destete, cambio_lote, tratamiento, cambio_dieta, cubricion, parto, entrada_cebo, salida_cebo

  details               String?   // New: Description/Notes
  cost                  Float     @default(0)
  status                String    @default("completed") // scheduled, pending, completed
  eventData             String?   // JSON for extra data

  notes                 String?

  @@index([farmId, date])
  @@index([animalId])
}

// 4. Motor: Objetivos, Métricas, Alertas y Predicciones

model Target {
  id                    String    @id @default(cuid())
  functionalType        String    // infiltracion, crecimiento_magro...
  stage                 String    // pre_destete, recria, terminado...
  
  minEnergy             Float
  minProtein            Float
  minFdn                Float
  minConcentrate        Float
  maxConcentrate        Float
  
  refAdg                Float
  refFcr                Float
  
  version               Int       @default(1)
}

model DailyMetric {
  id                    String    @id @default(cuid())
  animalId              String
  animal                Animal    @relation(fields: [animalId], references: [id])
  
  date                  DateTime
  calculatedStage       String
  
  totalDmKg             Float
  dietEnergy            Float
  dietProtein           Float
  dietFdn               Float
  dietAdf               Float
  
  adgObserved           Float?
  fcrObserved           Float?
  
  adgPredicted          Float?
  fcrPredicted          Float?

  @@unique([animalId, date])
}

model Alert {
  id                    String    @id @default(cuid())
  animalId              String
  animal                Animal    @relation(fields: [animalId], references: [id])
  
  date                  DateTime
  type                  String    // acidosis_riesgo, baja_ganancia, ineficiencia...
  severity              String    // info, warning, critical
  message               String
  ruleCode              String    // ej. RISK_ACIDOSIS_01
  
  resolvedAt            DateTime?
}

model QualityPrediction {
  id                    String    @id @default(cuid())
  animalId              String
  animal                Animal    @relation(fields: [animalId], references: [id])
  
  date                  DateTime
  qualityIndex          Float     // 0-100
  
  predTenderness        Float?
  predMarbling          Float?
  predColor             String?
  
  confidence            Float     // 0-1
  modelVersion          String
}

model TraceabilityReport {
  id                    String    @id @default(cuid())
  animalId              String
  animal                Animal    @relation(fields: [animalId], references: [id])

  issueDate             DateTime
  summaryJson           String    // JSON string
  qrToken               String    @unique
}

// Weekly SEUROP / MAPA reference prices.
//
// `code` is the lookup key used by PriceEngine: either the full grid cell
// (e.g. "AR3", "CU3") or the class ("AR", "CU") or just the MAPA letter
// ("A", "C") as a coarser fallback. The latest non-null entry for a given
// code wins — `week` lets us audit history and keep multiple weeks for
// trend analysis.
//
// Refreshed by `app/api/cron/refresh-prices` (configurable feed via
// PRICES_FEED_URL) or by a manual admin action.
model Price {
  id            String   @id @default(cuid())
  code          String
  pricePer100Kg Float
  week          String   // ISO week key, e.g. "2026-W20"
  source        String   @default("custom") // lonja_salamanca, mapa, eu_observatory, manual, custom
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([code, week])
  @@index([code])
  @@index([week])
}

// =============================================================================
// SPRINT 0 — Cimientos para campo, sanidad, costes, huella y pastoreo
// =============================================================================
//
// Los modelos a continuación dan soporte a las funcionalidades nuevas
// derivadas del análisis competitivo (softwareganadero, VacApp). Todo
// queda detrás del mismo permiso de finca/usuario que ya rige Animal,
// sin abrir suscripciones ni módulos de pago.

// --- HOJA DE VIDA DEL ANIMAL --------------------------------------------------
//
// Cualquier archivo adjunto a un animal: foto, ecografía, documento PDF
// (guía de origen, factura de compra, certificado), nota libre con fecha.
// El campo `url` puede apuntar a almacenamiento local (public/uploads/...)
// o a S3 cuando se conecte; no asumimos backend concreto aún.
model AnimalAttachment {
  id          String   @id @default(cuid())
  animalId    String
  animal      Animal   @relation(fields: [animalId], references: [id], onDelete: Cascade)

  type        String   // photo | ultrasound | document | note
  url         String?  // null si type=note (solo texto)
  caption     String?
  takenAt     DateTime @default(now())
  uploadedBy  String?  // userId que subió

  createdAt   DateTime @default(now())

  @@index([animalId])
  @@index([animalId, type])
}

// --- SANIDAD: CATÁLOGO DE PRODUCTOS VETERINARIOS ------------------------------
//
// Vademécum local de medicamentos veterinarios. Se siembra con un núcleo
// de productos AEMPS más frecuentes en vacuno; el usuario puede añadir
// los suyos. Los tiempos de retiro carne/leche son la fuente de verdad
// para bloquear ventas/lecheo durante el periodo.
model VetProduct {
  id                  String   @id @default(cuid())
  name                String   // nombre comercial
  activeIngredient    String?  // principio activo
  category            String   // antibiotico | antiparasitario | vacuna | hormonal | antiinflamatorio | otro
  presentation        String?  // inyectable / oral / pour-on / intramamario / intrauterino
  withdrawalMeatDays  Int      @default(0) // días de retiro en carne
  withdrawalMilkDays  Int      @default(0) // días de retiro en leche
  aemspCode           String?  // código nacional AEMPS si se conoce
  presvetCode         String?  // código PRESVET cuando exista
  unit                String   @default("ml") // unidad de dosis: ml, mg, dosis, comprimido
  defaultDosePerKg    Float?   // mg o ml por kg PV (orientativo)
  notes               String?

  records             HealthRecord[]
  stockMovements      VetStockMovement[]

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([category])
  @@index([name])
}

// --- SANIDAD: REGISTRO DE EVENTOS SANITARIOS ----------------------------------
//
// Cada tratamiento, vacunación, saneamiento (TB/brucelosis) o diagnóstico
// genera una fila aquí. Las fechas `withdrawalMeatUntil` y
// `withdrawalMilkUntil` se calculan a partir del producto en el momento
// del alta y bloquean ventas/lecheo desde la UI hasta esa fecha.
model HealthRecord {
  id                    String      @id @default(cuid())
  animalId              String
  animal                Animal      @relation(fields: [animalId], references: [id], onDelete: Cascade)

  type                  String      // treatment | vaccine | sanitation | diagnosis | deworming | other
  productId             String?
  product               VetProduct? @relation(fields: [productId], references: [id])

  diagnosis             String?     // si type=diagnosis: descripción
  dose                  Float?
  doseUnit              String?     // ml, mg, dosis...
  route                 String?     // IM, SC, IV, oral, pour-on, intramamaria
  vetName               String?     // veterinario responsable
  prescriptionRef       String?     // nº receta electrónica (futura integración PRESVET)
  campaignId            String?     // si pertenece a saneamiento oficial
  campaign              CampaignSchedule? @relation(fields: [campaignId], references: [id])

  appliedAt             DateTime
  withdrawalMeatUntil   DateTime?   // fecha hasta la que NO se puede sacrificar
  withdrawalMilkUntil   DateTime?   // fecha hasta la que NO se puede ordeñar

  cost                  Float?      // € total del tratamiento (alimenta CostEngine)
  notes                 String?

  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  @@index([animalId])
  @@index([animalId, appliedAt])
  @@index([productId])
  @@index([campaignId])
  @@index([withdrawalMeatUntil])
}

// --- SANIDAD: KARDEX DE STOCK VETERINARIO -------------------------------------
//
// Entradas (compras), salidas (uso clínico) y ajustes de inventario.
// El stock actual se calcula sumando deltas para no perder histórico.
model VetStockMovement {
  id          String     @id @default(cuid())
  farmId      String
  farm        Farm       @relation(fields: [farmId], references: [id], onDelete: Cascade)
  productId   String
  product     VetProduct @relation(fields: [productId], references: [id])

  kind        String     // entrada | salida | ajuste
  quantity    Float      // positivo siempre; el sentido lo da `kind`
  unit        String     // ml, mg, dosis, vial...
  unitCost    Float?     // €/unidad si entrada (compra)
  totalCost   Float?     // €/total movimiento
  reference   String?    // nº albarán, lote, motivo ajuste
  occurredAt  DateTime   @default(now())

  createdAt   DateTime   @default(now())

  @@index([farmId])
  @@index([farmId, productId])
  @@index([occurredAt])
}

// --- SANIDAD: CAMPAÑAS / SANEAMIENTOS OFICIALES -------------------------------
//
// TB, brucelosis, lengua azul, IBR... — campañas obligatorias por
// Comunidad Autónoma. Cada CampaignSchedule es un saneamiento concreto
// con su fecha objetivo. Los HealthRecord generados (uno por animal)
// quedan referenciados por `campaignId` para auditoría.
model CampaignSchedule {
  id              String   @id @default(cuid())
  farmId          String
  farm            Farm     @relation(fields: [farmId], references: [id], onDelete: Cascade)

  kind            String   // tuberculosis | brucelosis | lengua_azul | ibr | otro
  scheduledFor    DateTime
  completedAt     DateTime?
  result          String?  // pendiente | favorable | sospechoso | positivo
  vetName         String?
  notes           String?

  records         HealthRecord[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([farmId])
  @@index([farmId, scheduledFor])
}

// --- PASTOREO POR ANIMAL × PARCELA SIGPAC -------------------------------------
//
// Trazabilidad fina del pastoreo. Cada fila es un periodo en que un
// animal (o lote — futuro `herdId`) ha estado en una parcela concreta.
// Une nuestro SoilEngine (carga ganadera por suelo/recinto) con la idea
// de "dónde ha pastado cada vaca" tomada de VacApp.
//
// Tres formas de referenciar la parcela:
//   - corralId  → cuando el animal está en un corral nuestro
//   - cropPlotId → cuando pastorea una parcela de cultivo registrada
//   - sigpacRef  → solo string (provincia/municipio/polígono/parcela/recinto)
//     para parcelas no registradas en la app (campos ajenos, arriendos)
model GrazingEvent {
  id            String    @id @default(cuid())
  farmId        String
  farm          Farm      @relation(fields: [farmId], references: [id], onDelete: Cascade)
  animalId      String?   // si null, aplica al lote/corral entero
  animal        Animal?   @relation(fields: [animalId], references: [id], onDelete: SetNull)

  corralId      String?   // referencia opcional al corral nuestro
  cropPlotId    String?   // referencia opcional a parcela de cultivo
  sigpacRef     String?   // ej. "31/099/5/142/3" — provincia/muni/polig/parc/recinto

  startAt       DateTime
  endAt         DateTime?
  areaHa        Float?    // hectáreas ocupadas (auto desde corral/plot si no se introduce)
  lu            Float?    // unidades ganaderas asignadas (auto)

  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([farmId])
  @@index([farmId, startAt])
  @@index([animalId])
  @@index([corralId])
  @@index([cropPlotId])
}

// --- HUELLA DE CARBONO IPCC ---------------------------------------------------
//
// Calculado por EmissionEngine (Sprint 1.1) por finca y grupo (categoría
// animal + periodo). Se guarda para histórico/dashboard y para alimentar
// la narrativa PAC + ecorregímenes.
//
// Unidades:
//   - ch4Enteric, ch4Manure, n2oManure, n2oSoil: kg gas en el periodo
//   - co2eqTotal: kg CO2 equivalente (GWP100 AR6: CH4=27.9 no-fossil, N2O=273)
//   - intensityPerKgCarcass: kg CO2eq / kg canal producido en el periodo
//   - intensityPerKgLive:    kg CO2eq / kg vivo producido en el periodo
model EmissionRecord {
  id                      String   @id @default(cuid())
  farmId                  String
  farm                    Farm     @relation(fields: [farmId], references: [id], onDelete: Cascade)

  groupKey                String   // ej. "vaca_seca" | "ternero" | "novilla" | "toro" | "total"
  periodFrom              DateTime
  periodTo                DateTime

  headcount               Float    // nº cabezas equivalentes en el periodo
  lu                      Float    // unidades ganaderas equivalentes

  ch4Enteric              Float    // kg CH4 fermentación entérica
  ch4Manure               Float    // kg CH4 gestión estiércol
  n2oManure               Float    // kg N2O directo + indirecto estiércol
  n2oSoil                 Float    // kg N2O deposiciones directas pastoreo
  co2eqTotal              Float    // kg CO2eq (GWP100 AR6)

  liveWeightKg            Float?   // kg vivo producido en el periodo
  carcassKg               Float?   // kg canal producido en el periodo
  intensityPerKgLive      Float?   // kg CO2eq / kg vivo
  intensityPerKgCarcass   Float?   // kg CO2eq / kg canal

  methodology             String   @default("IPCC2019_Tier1") // IPCC2019_Tier1 | IPCC2019_Tier2
  notes                   String?

  createdAt               DateTime @default(now())

  @@index([farmId])
  @@index([farmId, periodFrom])
}

// --- SIMULACIÓN "¿QUÉ PASARÍA SI?" --------------------------------------------
//
// Almacena escenarios para comparar. baseline y scenario son snapshots
// JSON con los parámetros (precios, GMD, mortalidad, IEP, coste alim).
// result es el output que renderiza el dashboard sin recalcular.
model Simulation {
  id              String   @id @default(cuid())
  farmId          String
  farm            Farm     @relation(fields: [farmId], references: [id], onDelete: Cascade)
  createdBy       String?  // userId

  name            String
  baselineJson    String   // snapshot variables actuales
  scenarioJson    String   // overrides (deltas o valores absolutos)
  resultJson      String?  // output cacheado del motor
  notes           String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([farmId])
  @@index([farmId, createdAt])
}

// --- COSTES DE PRODUCCIÓN (€/kg) ----------------------------------------------
//
// Diario libro de costes. Cada fila imputa un coste real o estimado a
// una finca y, opcionalmente, a un animal concreto. Las fuentes
// automáticas (ración, evento sanitario, mortalidad) generan filas con
// `source` distinto a "manual" para que el motor pueda recalcular sin
// pisar entradas manuales.
model CostEntry {
  id          String    @id @default(cuid())
  farmId      String
  farm        Farm      @relation(fields: [farmId], references: [id], onDelete: Cascade)
  animalId    String?
  animal      Animal?   @relation(fields: [animalId], references: [id], onDelete: SetNull)

  category    String    // alimentacion | sanidad | mano_obra | amortizacion | servicios | otros
  amount      Float     // €
  date        DateTime
  source      String    @default("manual") // manual | ration | health | event | depreciation
  reference   String?   // ID del registro origen si aplica
  notes       String?

  createdAt   DateTime  @default(now())

  @@index([farmId])
  @@index([farmId, date])
  @@index([animalId])
}

// --- BIENESTAR ANIMAL (Welfare Quality® / Welfair / B+ PAWS) ------------------
//
// Una `WelfareAssessment` es una sesión de evaluación interna que el
// ganadero usa para preparar la auditoría externa (SGS, Bureau Veritas)
// o para autocontrol periódico. Cada sesión tiene N `WelfareIndicator`,
// uno por cada criterio Welfare Quality que se mide.
//
// Modelo común a Welfair (IRTA + NEIKER) y PAWS (PROVACUNO). Se
// diferencian en el `protocol` y en algunos pesos al puntuar, pero la
// estructura de 4 principios × 12 criterios es la misma porque ambos
// están construidos sobre Welfare Quality®.
model WelfareAssessment {
    id            String   @id @default(cuid())
    farmId        String
    farm          Farm     @relation(fields: [farmId], references: [id], onDelete: Cascade)

    date          DateTime @default(now())
    protocol      String   // 'welfair' | 'paws'
    status        String   @default("preparando") // preparando | lista | auditada | aprobada | rechazada
    auditorName   String?
    /// Score 0-100 global agregado por el motor.
    overallScore  Float?
    notes         String?
    createdBy     String?  // userId

    createdAt     DateTime @default(now())
    updatedAt     DateTime @updatedAt

    indicators    WelfareIndicator[]

    @@index([farmId])
    @@index([farmId, date])
}

// Una fila por (assessment, indicatorCode). Cada indicador pertenece a
// un criterio (C1-C12) que a su vez pertenece a un principio (1-4).
//
// El valor se guarda en uno de los tres campos según el tipo:
//   - valueNumeric: BCS, % cojeras, m² por cabeza, etc.
//   - valueText: respuestas categóricas ("sí/no", "diario/semanal", QBA…)
//   - valueBool: tests pasa/no-pasa.
//
// `source` distingue lo que viene auto-precomputado por motor (`auto`)
// vs lo introducido manualmente por el ganadero (`manual`). El motor
// nunca pisa valores manuales.
//
// `score` (0-100) lo asigna `welfareEngine.scoreAssessment()` tras la
// evaluación; se persiste para no recalcular en cada lectura.
model WelfareIndicator {
    id              String   @id @default(cuid())
    assessmentId    String
    assessment      WelfareAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

    principle       Int      // 1..4
    criterion       String   // 'C1' ... 'C12'
    indicatorCode   String   // ej. 'BCS_HERD', 'WATER_FLOW', 'LAMENESS_PCT', 'QBA'

    valueNumeric    Float?
    valueText       String?
    valueBool       Boolean?
    score           Float?   // 0-100
    /// Estado de cumplimiento: 'excelente' | 'aceptable' | 'mejorable' | 'alarmante' | 'sin_dato'
    status          String   @default("sin_dato")
    /// Origen del valor — 'auto' (motor) o 'manual' (introducido).
    source          String   @default("manual")
    notes           String?
    /// Fotos / documentos como evidencia (URLs en /uploads).
    evidenceUrls    String[] @default([])

    createdAt       DateTime @default(now())
    updatedAt       DateTime @updatedAt

    @@unique([assessmentId, indicatorCode])
    @@index([assessmentId])
    @@index([assessmentId, principle])
}

// --- REGLAS DE ALERTA CONFIGURABLES -------------------------------------------
//
// El AlertEngine evalúa estas reglas en un cron nocturno y genera filas
// en el modelo `Alert` existente. Cada AlertRule tiene un `kind` que el
// motor entiende y `params` JSON con los umbrales.
//
// kinds soportados (Sprint 1.3):
//   - hembras_a_parir       → params: { daysAhead: 7 }
//   - sin_pesar             → params: { daysSince: 60 }
//   - perdiendo_peso        → params: { weeksOfLoss: 2, thresholdPct: 5 }
//   - retiro_vencido        → params: { warnDaysBefore: 3 }
//   - saneamiento_proximo   → params: { daysAhead: 14 }
//   - carga_excedida        → params: { tolerancePct: 10 }
model AlertRule {
  id          String   @id @default(cuid())
  farmId      String
  farm        Farm     @relation(fields: [farmId], references: [id], onDelete: Cascade)

  kind        String
  enabled     Boolean  @default(true)
  paramsJson  String   @default("{}")
  severity    String   @default("warning") // info | warning | critical
  channels    String[] @default(["app"])   // app | email (futuro)

  lastEvalAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([farmId, kind])
  @@index([farmId])
}
