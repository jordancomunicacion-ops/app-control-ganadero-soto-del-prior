# === BASE DE DATOS ===
# Cadena de conexión PostgreSQL. Formato: postgresql://user:pass@host:port/db
DATABASE_URL="postgresql://user:password@localhost:5432/livestock_db"

# === AUTENTICACIÓN (NextAuth) ===
# OBLIGATORIO en producción. La app rehúsa arrancar si no está definido.
# Genera con: openssl rand -base64 32
AUTH_SECRET="your-secret-here"
# URL pública de la aplicación (usada para enlaces de reset password y callbacks de auth).
NEXTAUTH_URL="http://localhost:3001"
# Email del usuario maestro que puede entrar incluso sin estar "aprobado". Opcional.
MASTER_ADMIN_EMAIL="gerencia@sotodelprior.com"

# === EMAIL (SMTP) ===
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="tu-email@gmail.com"
SMTP_PASS="tu-app-password"
SMTP_FROM='"Soto del Prior" <noreply@sotodelprior.com>'

# === ENTORNO ===
# Usar "production" en despliegues reales para habilitar cookies Secure.
NODE_ENV="development"
